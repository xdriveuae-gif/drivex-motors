# ───────────────────────────────────────────────────────────────
#  DriveX Motors — Environment configuration
#  Copy this file to ".env" and adjust the values for your machine.
#  NEVER commit your real .env file.
# ───────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Public base URL of the site (used for canonical links, sitemap.xml and Open Graph tags)
SITE_URL=http://localhost:3000

# Session — generate a long random string for production!
# e.g. node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=please-change-me-to-a-long-random-secret

# Database
DB_PATH=./database/database.db

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=8
MAX_IMAGES_PER_VEHICLE=12

# Default administrator — created automatically on first boot if no admin exists.
# CHANGE THESE before deploying to production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123

# ── Business / contact details (shown across the public site) ──
# These have sensible Abu Dhabi placeholder defaults in config/site.js;
# set them here to override without touching code.
SITE_PHONE=+971 2 555 0199
SITE_WHATSAPP=971501234567
SITE_EMAIL=sales@drivexmotors.ae
SITE_ADDRESS=Al Maqta'a, Abu Dhabi, United Arab Emirates
SITE_MAP_QUERY=Abu Dhabi, United Arab Emirates
